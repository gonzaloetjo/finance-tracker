# Override XDG paths if you want (optional)
# FINANCE_CONFIG_DIR=~/.config/finance
# FINANCE_DATA_DIR=~/.local/share/finance


# Pre-set the passphrase for decrypting the RSA key in non-interactive runs.
# If unset, CLI prompts interactively on first use.
# FINANCE_KEY_PASSPHRASE=

# SECURITY: if set, never commit this file. .gitignore excludes `.env`,
# but double-check before sharing a snapshot.
